{
  "realm": "goktuggpt",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 1800,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,

  "clients": [
    {
      "clientId": "goktuggpt-web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "goktuggpt-internal",
      "enabled": true,
      "publicClient": false,
      "secret": "internal-dev-secret-change-in-prod",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false
    }
  ],

  "roles": {
    "realm": [
      { "name": "user",      "description": "Standard end-user" },
      { "name": "pro",       "description": "Pro plan subscriber" },
      { "name": "enterprise","description": "Enterprise tenant" },
      { "name": "admin",     "description": "Platform admin" }
    ]
  }
}
