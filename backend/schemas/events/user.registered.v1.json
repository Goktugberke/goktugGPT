{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://goktug.dev/schemas/events/user.registered.v1.json",
  "title": "user.registered.v1",
  "description": "identity-service yeni kullanıcı kaydında yayınlar. Tüketiciler: billing-service (free plan oluştur), notification-service (welcome mail).",
  "type": "object",
  "required": ["eventId", "eventType", "occurredAt", "producer", "payload"],
  "additionalProperties": true,
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "const": "user.registered.v1" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "producer": { "type": "string" },
    "traceId": { "type": "string" },
    "userId": { "type": "string", "format": "uuid" },
    "payload": {
      "type": "object",
      "required": ["userId", "email", "registeredAt"],
      "additionalProperties": true,
      "properties": {
        "userId": { "type": "string", "format": "uuid" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "registeredAt": { "type": "string", "format": "date-time" },
        "source": { "type": "string" }
      }
    }
  }
}
