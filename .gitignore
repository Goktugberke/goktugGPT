# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
.env

# ── Model weights & checkpoints (can be hundreds of MB / GB) ─────────────────
checkpoints/*.pt
checkpoints/*.pth
checkpoints/loss_history.txt

# Tokenizer IS committed — Kaggle needs it without re-training
# checkpoints/tokenizer.json   ← intentionally NOT ignored

# Keep the checkpoints folder itself
!checkpoints/.gitkeep

# ── Training data — large files, uploaded to Kaggle as Dataset ───────────────
data/train_clean.txt
data/val_clean.txt

# ── Old/legacy data files — no longer used ───────────────────────────────────
data/raw/
data/*.zip
data/train_big.txt
data/train_combined.txt
data/train_original_backup.txt
data/train.txt
data/train_chat_big.txt
data/conversations/

# alpaca_data.json — local cache for prepare_data.py, re-downloadable
data/alpaca_data.json

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
