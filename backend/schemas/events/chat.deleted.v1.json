{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://goktug.dev/schemas/events/chat.deleted.v1.json",
  "title": "chat.deleted.v1",
  "description": "conversation-service chat silinince (soft delete) yayınlar. Tüketici: ChatSearchProjector (ES markDeleted).",
  "type": "object",
  "required": ["eventId", "eventType", "occurredAt", "producer", "payload"],
  "additionalProperties": true,
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "const": "chat.deleted.v1" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "producer": { "type": "string" },
    "traceId": { "type": "string" },
    "userId": { "type": "string", "format": "uuid" },
    "payload": {
      "type": "object",
      "required": ["chatId", "userId"],
      "additionalProperties": true,
      "properties": {
        "chatId": { "type": "string", "format": "uuid" },
        "userId": { "type": "string", "format": "uuid" }
      }
    }
  }
}
