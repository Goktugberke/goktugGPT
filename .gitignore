# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
.env

# ── Model weights & checkpoints (can be hundreds of MB / GB) ─────────────────
checkpoints/*.pt
checkpoints/*.pth
# Tokenizer is a generated artifact — regenerated by train.py
checkpoints/tokenizer.json
checkpoints/loss_history.txt

# Keep the checkpoints folder itself
!checkpoints/.gitkeep

# ── Raw downloaded training data (re-downloadable, can be GB) ────────────────
data/raw/
data/*.zip
data/train_big.txt
data/train_combined.txt
data/train_original_backup.txt
data/alpaca_data.json

# Generated conversation datasets — re-created by download_conversations.py
data/train_chat.txt
data/train_chat_big.txt
data/conversations/

# train.txt is generated by generate_data.py — too large for GitHub (79MB)
data/train.txt

# Keep scripts
!data/download_data.py
!data/prepare_data.py
!data/download_conversations.py
!data/download_big.py

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
